{% comment %}
  Tree Master - Custom Menu Block
  Renders custom HTML/CSS from the Tree Master app via app proxy.
{% endcomment %}

{% assign menu_id = block.settings.custom_menu_id %}

{% if menu_id != blank %}
  <div class="tree-master-menu tree-master-custom" data-menu-id="{{ menu_id }}" {{ block.shopify_attributes }}>
    <div class="tree-master-menu-content" id="tree-menu-{{ menu_id }}">
      <noscript>
        <p>Enable JavaScript to view this custom menu.</p>
      </noscript>
    </div>
  </div>

  <script>
    (function() {
      var menuId = "{{ menu_id }}";
      var container = document.getElementById("tree-menu-" + menuId);
      if (!container) return;

      fetch("/apps/tree-master/menu/" + menuId)
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.html) {
            container.innerHTML = data.html;
          }
          if (data.css) {
            var style = document.createElement("style");
            style.textContent = data.css;
            container.appendChild(style);
          }
        })
        .catch(function(err) {
          console.error("Tree Master: Failed to load menu", err);
        });
    })();
  </script>

{% else %}
  <div {{ block.shopify_attributes }}>
    <p style="color: #888; text-align: center; padding: 20px;">Enter a Custom Menu ID in the block settings.</p>
  </div>
{% endif %}

{% schema %}
{
  "name": "Tree Master Menu",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "custom_menu_id",
      "label": "Custom Menu ID",
      "info": "Enter the menu ID from the Tree Master app. Find it under Custom Menus in the app."
    }
  ]
}
{% endschema %}
