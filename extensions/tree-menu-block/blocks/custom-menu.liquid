{% comment %}
  Tree Master - App Embed
  • Custom Menu: replaces header nav with a custom-coded menu
  • Native Badges: replaces header nav with a Shopify menu + optional badges
{% endcomment %}

{% assign menu_id = block.settings.custom_menu_id %}
{% assign nav_selector = block.settings.nav_selector %}
{% assign native_menu_handle = block.settings.native_menu_handle %}
{% assign badge_color = block.settings.badge_color %}
{% assign badge_text_color = block.settings.badge_text_color %}
{% if nav_selector == blank %}{% assign nav_selector = "header nav" %}{% endif %}

{% if menu_id != blank or native_menu_handle != blank %}
<style>
  .tm-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 9px;
    font-weight: 800;
    line-height: 1;
    padding: 3px 7px;
    border-radius: 20px;
    margin-left: 6px;
    vertical-align: middle;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background-color: {{ badge_color | default: '#FF4438' }};
    color: {{ badge_text_color | default: '#ffffff' }};
    white-space: nowrap;
    pointer-events: none;
    position: relative;
    top: -1px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.18);
    animation: tm-badge-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes tm-badge-pop {
    from { transform: scale(0.6); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }
  #tm-native-menu-data { display: none !important; }

  /* Dropdown for injected native menu items */
  .tm-has-dropdown { position: relative; }
  .tm-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 9999;
    min-width: 160px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 6px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    list-style: none;
    padding: 6px 0;
    margin: 4px 0 0 0;
  }
  .tm-has-dropdown:hover > .tm-dropdown,
  .tm-has-dropdown:focus-within > .tm-dropdown { display: block; }
  .tm-dropdown li { list-style: none; }
  .tm-dropdown a {
    display: block;
    padding: 8px 16px;
    white-space: nowrap;
    text-decoration: none;
    color: inherit;
  }
  .tm-dropdown a:hover { background: rgba(0,0,0,0.05); }
</style>

{% comment %} Hidden menu data rendered server-side from linklists {% endcomment %}
{% if native_menu_handle != blank %}
  {% assign native_linklist = linklists[native_menu_handle] %}
  {% if native_linklist.links.size > 0 %}
  <ul id="tm-native-menu-data" aria-hidden="true">
    {% for link in native_linklist.links %}
    <li data-title="{{ link.title | escape }}" data-url="{{ link.url | escape }}">
      {% if link.links.size > 0 %}
      <ul>
        {% for sub in link.links %}
        <li data-title="{{ sub.title | escape }}" data-url="{{ sub.url | escape }}"></li>
        {% endfor %}
      </ul>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
  {% endif %}
{% endif %}

<script>
  (function() {
    var menuId = {{ menu_id | json }};
    var customSelector = {{ nav_selector | json }};
    var nativeMenuHandle = {{ native_menu_handle | json }};
    var shop = {{ shop.permanent_domain | json }};

    // Fallback selectors — more specific first (Dawn, Refresh, Sense, etc.)
    var fallbackSelectors = [
      customSelector,
      ".header__inline-menu",
      "header .header__navigation",
      ".site-navigation",
      ".site-nav",
      "header nav",
      "header [role='navigation']"
    ];

    function isVisible(el) {
      if (!el) return false;
      var style = window.getComputedStyle(el);
      if (style.display === "none" || style.visibility === "hidden" || style.opacity === "0") return false;
      var rect = el.getBoundingClientRect();
      return rect.width > 0 || rect.height > 0;
    }

    function findNav() {
      for (var i = 0; i < fallbackSelectors.length; i++) {
        var candidates = document.querySelectorAll(fallbackSelectors[i]);
        for (var j = 0; j < candidates.length; j++) {
          if (isVisible(candidates[j])) {
            console.log("Tree Master: nav found with selector \"" + fallbackSelectors[i] + "\"");
            return candidates[j];
          }
        }
      }
      return null;
    }

    // Read menu items from the hidden server-rendered <ul>
    function getMenuItemsFromDOM() {
      var container = document.getElementById('tm-native-menu-data');
      if (!container) return null;
      var topLis = container.querySelectorAll(':scope > li');
      if (!topLis.length) return null;
      var items = [];
      topLis.forEach(function(li) {
        var item = {
          title: li.getAttribute('data-title') || '',
          url: li.getAttribute('data-url') || '#',
          links: []
        };
        li.querySelectorAll(':scope > ul > li').forEach(function(subLi) {
          item.links.push({
            title: subLi.getAttribute('data-title') || '',
            url: subLi.getAttribute('data-url') || '#'
          });
        });
        items.push(item);
      });
      return items.length ? items : null;
    }

    // ---- Badge helpers ----
    function makeBadgeSpan(text) {
      var span = document.createElement('span');
      span.className = 'tm-badge';
      span.textContent = text;
      return span;
    }

    function getLinkText(link) {
      var clone = link.cloneNode(true);
      clone.querySelectorAll('.tm-badge').forEach(function(b) { b.remove(); });
      return clone.textContent.trim();
    }

    function injectBadgesOnly(badges) {
      if (!badges || Object.keys(badges).length === 0) return;
      var links = document.querySelectorAll('header a, nav a, [role="navigation"] a');
      links.forEach(function(link) {
        var text = getLinkText(link);
        if (text && badges[text] && !link.querySelector('.tm-badge')) {
          link.appendChild(makeBadgeSpan(badges[text]));
        }
      });
    }

    // ---- Native menu injection (clone-based, preserves theme CSS) ----

    // Update a link element's text node + badge, keeping SVGs/icons intact
    function updateLinkContent(linkEl, title, badge) {
      linkEl.querySelectorAll('.tm-badge').forEach(function(b) { b.remove(); });
      var updated = false;
      linkEl.childNodes.forEach(function(node) {
        if (!updated && node.nodeType === 3 && node.nodeValue.trim()) {
          node.nodeValue = title;
          updated = true;
        }
      });
      if (!updated) {
        linkEl.insertBefore(document.createTextNode(title), linkEl.firstChild);
      }
      if (badge) linkEl.appendChild(makeBadgeSpan(badge));
    }

    function buildAndInjectNativeMenu(items, badges) {
      if (!items || !items.length) return false;

      var nav = findNav();
      if (!nav) {
        console.warn("Tree Master: could not find header navigation. Try setting a custom CSS selector.");
        return false;
      }

      // Work on the <ul> that contains top-level nav items
      var navList = nav.querySelector('ul') || nav;
      var existingLis = navList.querySelectorAll(':scope > li');
      if (!existingLis.length) return false;

      // Pick templates from the existing nav
      var simpleLiTemplate = null;
      var dropdownLiTemplate = null;
      existingLis.forEach(function(li) {
        if (!dropdownLiTemplate && li.querySelector('ul')) dropdownLiTemplate = li;
        if (!simpleLiTemplate && !li.querySelector('ul'))  simpleLiTemplate = li;
      });
      if (!simpleLiTemplate) simpleLiTemplate = existingLis[0];

      var fragment = document.createDocumentFragment();

      items.forEach(function(item) {
        var hasDropdown = item.links && item.links.length > 0;
        var template = (hasDropdown && dropdownLiTemplate) ? dropdownLiTemplate : simpleLiTemplate;
        var newLi = template.cloneNode(true);

        // Find the top-level anchor to update
        var topLink = newLi.querySelector(':scope > a')
          || newLi.querySelector(':scope > details > summary > a')
          || newLi.querySelector('a');

        if (topLink) {
          topLink.href = item.url;
          updateLinkContent(topLink, item.title, badges[item.title.trim()]);
        }

        // Update sub-items inside the cloned dropdown structure
        if (hasDropdown && dropdownLiTemplate) {
          var subList = newLi.querySelector('ul');
          if (subList) {
            var subLiTemplate = subList.querySelector('li');
            subList.innerHTML = '';
            item.links.forEach(function(sub) {
              var newSubLi = subLiTemplate
                ? subLiTemplate.cloneNode(true)
                : document.createElement('li');
              var subLink = newSubLi.querySelector('a') || document.createElement('a');
              subLink.href = sub.url;
              updateLinkContent(subLink, sub.title, badges[sub.title.trim()]);
              if (!newSubLi.contains(subLink)) newSubLi.appendChild(subLink);
              subList.appendChild(newSubLi);
            });
          }
        } else if (hasDropdown) {
          // No dropdown template in theme — use CSS fallback
          var fbUl = document.createElement('ul');
          fbUl.className = 'tm-dropdown';
          item.links.forEach(function(sub) {
            var fbLi = document.createElement('li');
            var fbA  = document.createElement('a');
            fbA.href = sub.url;
            fbA.textContent = sub.title;
            var subBadge = badges[sub.title.trim()];
            if (subBadge) fbA.appendChild(makeBadgeSpan(subBadge));
            fbLi.appendChild(fbA);
            fbUl.appendChild(fbLi);
          });
          newLi.classList.add('tm-has-dropdown');
          newLi.appendChild(fbUl);
        }

        fragment.appendChild(newLi);
      });

      navList.setAttribute('data-tree-master-original', navList.innerHTML);
      navList.setAttribute('data-tree-master-native', nativeMenuHandle);
      navList.innerHTML = '';
      navList.appendChild(fragment);
      console.log("Tree Master: native menu injected (" + items.length + " items, theme CSS preserved).");
      return true;
    }

    function loadNativeBadges() {
      if (!nativeMenuHandle) return;

      var items = getMenuItemsFromDOM();

      // Fetch badges then build/inject
      fetch('/apps/tree-master/native-badges/' + nativeMenuHandle + '?shop=' + shop)
        .then(function(res) { return res.ok ? res.json() : null; })
        .then(function(data) {
          var badges = (data && data.badges) ? data.badges : {};
          if (items) {
            buildAndInjectNativeMenu(items, badges);
          } else {
            injectBadgesOnly(badges);
          }
        })
        .catch(function() {
          if (items) buildAndInjectNativeMenu(items, {});
        });
    }

    // ---- Custom menu injection ----
    function injectMenu() {
      fetch("/apps/tree-master/menu/" + menuId)
        .then(function(res) {
          if (!res.ok) throw new Error("HTTP " + res.status);
          return res.json();
        })
        .then(function(data) {
          if (!data.html) {
            console.warn("Tree Master: menu has no HTML. Is it published?");
            return;
          }

          var nav = findNav();
          if (!nav) {
            console.warn("Tree Master: could not find header navigation. Try setting a custom CSS selector in App Embeds settings.");
            return;
          }

          if (data.css) {
            var style = document.createElement("style");
            style.setAttribute("data-tree-master", menuId);
            style.textContent = data.css;
            document.head.appendChild(style);
          }

          nav.setAttribute("data-tree-master-original", nav.innerHTML);
          nav.setAttribute("data-tree-master-id", menuId);
          nav.innerHTML = data.html;

          if (data.js) {
            try {
              var fn = new Function(data.js);
              fn();
            } catch (e) {
              console.error("Tree Master: JS error:", e);
            }
          }

          console.log("Tree Master: menu injected successfully.");
        })
        .catch(function(err) {
          console.error("Tree Master: Failed to load menu.", err);
        });
    }

    function init() {
      if (menuId) injectMenu();
      if (nativeMenuHandle) loadNativeBadges();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
{% endif %}

{% schema %}
{
  "name": "Tree Master Menu",
  "target": "body",
  "settings": [
    {
      "type": "header",
      "content": "Custom Code Menu"
    },
    {
      "type": "text",
      "id": "custom_menu_id",
      "label": "Custom Menu ID",
      "info": "Enter the menu ID from the Tree Master app (Custom Menus section). Leave empty if not using a custom menu."
    },
    {
      "type": "text",
      "id": "nav_selector",
      "label": "Navigation CSS Selector (optional)",
      "placeholder": "header nav",
      "info": "Leave empty to auto-detect. If the menu doesn't appear, open DevTools, find your nav element, and enter its selector here."
    },
    {
      "type": "header",
      "content": "Native Menu Badges"
    },
    {
      "type": "text",
      "id": "native_menu_handle",
      "label": "Menu Handle",
      "info": "Enter your Shopify menu handle (e.g. 'main-menu'). The menu items will be displayed in your header navigation. To show badges, add them to items in Tree Master and Save."
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge Color",
      "default": "#FF4438"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
