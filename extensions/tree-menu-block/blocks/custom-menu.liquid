{% comment %}
  Tree Master - App Embed
  • Custom Menu: replaces header nav with a custom-coded menu
  • Native Badges: replaces header nav with a Shopify menu + optional badges
{% endcomment %}

{% assign menu_id = block.settings.custom_menu_id %}
{% assign nav_selector = block.settings.nav_selector %}
{% assign native_menu_handle = block.settings.native_menu_handle %}
{% assign badge_color = block.settings.badge_color %}
{% assign badge_text_color = block.settings.badge_text_color %}
{% if nav_selector == blank %}{% assign nav_selector = "header nav" %}{% endif %}

{% if menu_id != blank or native_menu_handle != blank %}
<style>
  .tm-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 9px;
    font-weight: 800;
    line-height: 1;
    padding: 3px 7px;
    border-radius: 20px;
    margin-left: 6px;
    vertical-align: middle;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background-color: {{ badge_color | default: '#FF4438' }};
    color: {{ badge_text_color | default: '#ffffff' }};
    white-space: nowrap;
    pointer-events: none;
    position: relative;
    top: -1px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.18);
    animation: tm-badge-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes tm-badge-pop {
    from { transform: scale(0.6); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }
  #tm-native-menu-data { display: none !important; }
</style>

{% comment %} Hidden menu data rendered server-side from linklists {% endcomment %}
{% if native_menu_handle != blank %}
  {% assign native_linklist = linklists[native_menu_handle] %}
  {% if native_linklist.links.size > 0 %}
  <ul id="tm-native-menu-data" aria-hidden="true">
    {% for link in native_linklist.links %}
    <li data-title="{{ link.title | escape }}" data-url="{{ link.url | escape }}">
      {% if link.links.size > 0 %}
      <ul>
        {% for sub in link.links %}
        <li data-title="{{ sub.title | escape }}" data-url="{{ sub.url | escape }}"></li>
        {% endfor %}
      </ul>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
  {% endif %}
{% endif %}

<script>
  (function() {
    var menuId = {{ menu_id | json }};
    var customSelector = {{ nav_selector | json }};
    var nativeMenuHandle = {{ native_menu_handle | json }};
    var shop = {{ shop.permanent_domain | json }};

    var fallbackSelectors = [
      customSelector,
      ".header__inline-menu",
      "header .header__navigation",
      ".site-navigation",
      ".site-nav",
      "header nav",
      "header [role='navigation']",
      ".nav-bar",
      ".main-nav",
      ".primary-nav"
    ];

    function isVisible(el) {
      if (!el) return false;
      var s = window.getComputedStyle(el);
      if (s.display === "none" || s.visibility === "hidden" || s.opacity === "0") return false;
      var r = el.getBoundingClientRect();
      return r.width > 0 || r.height > 0;
    }

    function findNav() {
      // 1. Try known selectors
      for (var i = 0; i < fallbackSelectors.length; i++) {
        var sel = fallbackSelectors[i];
        if (!sel) continue;
        var candidates = document.querySelectorAll(sel);
        for (var j = 0; j < candidates.length; j++) {
          if (isVisible(candidates[j])) {
            console.log("Tree Master: nav found → \"" + sel + "\"");
            return candidates[j];
          }
        }
      }
      // 2. Last resort: any <nav> or <ul> in <header> that contains multiple links
      var headers = document.querySelectorAll('header, [role="banner"]');
      for (var h = 0; h < headers.length; h++) {
        var containers = headers[h].querySelectorAll('nav, ul');
        for (var c = 0; c < containers.length; c++) {
          var el = containers[c];
          if (el.querySelectorAll('a').length >= 2 && isVisible(el)) {
            console.log("Tree Master: nav found via header fallback");
            return el;
          }
        }
      }
      return null;
    }

    // Read menu items from the hidden server-rendered <ul>
    function getMenuItemsFromDOM() {
      var container = document.getElementById('tm-native-menu-data');
      if (!container) return null;
      var topLis = container.querySelectorAll(':scope > li');
      if (!topLis.length) return null;
      var items = [];
      topLis.forEach(function(li) {
        var item = {
          title: li.getAttribute('data-title') || '',
          url: li.getAttribute('data-url') || '#',
          links: []
        };
        li.querySelectorAll(':scope > ul > li').forEach(function(subLi) {
          item.links.push({
            title: subLi.getAttribute('data-title') || '',
            url: subLi.getAttribute('data-url') || '#'
          });
        });
        items.push(item);
      });
      return items.length ? items : null;
    }

    // ---- Badge helpers ----
    function makeBadgeSpan(text) {
      var span = document.createElement('span');
      span.className = 'tm-badge';
      span.textContent = text;
      return span;
    }

    function getLinkText(link) {
      var clone = link.cloneNode(true);
      clone.querySelectorAll('.tm-badge').forEach(function(b) { b.remove(); });
      return clone.textContent.trim();
    }

    function injectBadgesOnly(badges) {
      if (!badges || Object.keys(badges).length === 0) return;
      document.querySelectorAll('header a, nav a, [role="navigation"] a').forEach(function(link) {
        var text = getLinkText(link);
        if (text && badges[text] && !link.querySelector('.tm-badge')) {
          link.appendChild(makeBadgeSpan(badges[text]));
        }
      });
    }

    // ---- Native menu injection ----
    function buildAndInjectNativeMenu(items, badges) {
      if (!items || !items.length) return false;

      var nav = findNav();
      if (!nav) {
        console.warn("Tree Master: nav not found. Set a CSS selector in App Embeds settings.");
        return false;
      }

      // Read theme's existing link styles BEFORE we clear the nav
      var existingLink = nav.querySelector('a');
      var cs = existingLink ? window.getComputedStyle(existingLink) : null;
      var linkColor      = cs ? cs.color : 'inherit';
      var linkFont       = cs ? cs.fontFamily : 'inherit';
      var linkSize       = cs ? cs.fontSize : 'inherit';
      var linkWeight     = cs ? cs.fontWeight : 'inherit';
      var linkSpacing    = cs ? cs.letterSpacing : 'normal';
      var linkTransform  = cs ? cs.textTransform : 'none';
      var linkPadding    = cs ? cs.padding : '0 12px';

      // Build the nav list
      var ul = document.createElement('ul');
      ul.style.cssText = [
        'list-style:none',
        'display:flex',
        'align-items:center',
        'flex-wrap:wrap',
        'margin:0',
        'padding:0',
        'gap:0'
      ].join(';');

      items.forEach(function(item) {
        var li = document.createElement('li');
        li.style.cssText = 'list-style:none;position:relative;';

        var a = document.createElement('a');
        a.href = item.url;
        a.textContent = item.title;
        a.style.cssText = [
          'display:inline-flex',
          'align-items:center',
          'text-decoration:none',
          'cursor:pointer',
          'color:' + linkColor,
          'font-family:' + linkFont,
          'font-size:' + linkSize,
          'font-weight:' + linkWeight,
          'letter-spacing:' + linkSpacing,
          'text-transform:' + linkTransform,
          'padding:' + linkPadding
        ].join(';');

        var badge = badges[item.title.trim()];
        if (badge) a.appendChild(makeBadgeSpan(badge));
        li.appendChild(a);

        // Sub-items dropdown
        if (item.links && item.links.length) {
          var subUl = document.createElement('ul');
          subUl.style.cssText = [
            'display:none',
            'position:absolute',
            'top:100%',
            'left:0',
            'list-style:none',
            'margin:4px 0 0 0',
            'padding:6px 0',
            'min-width:180px',
            'background:#fff',
            'border:1px solid rgba(0,0,0,0.1)',
            'border-radius:6px',
            'box-shadow:0 4px 16px rgba(0,0,0,0.12)',
            'z-index:9999'
          ].join(';');

          item.links.forEach(function(sub) {
            var subLi = document.createElement('li');
            subLi.style.listStyle = 'none';
            var subA = document.createElement('a');
            subA.href = sub.url;
            subA.textContent = sub.title;
            subA.style.cssText = [
              'display:block',
              'padding:8px 16px',
              'text-decoration:none',
              'white-space:nowrap',
              'color:#333',
              'font-family:' + linkFont,
              'font-size:' + linkSize
            ].join(';');
            subA.addEventListener('mouseenter', function() { this.style.background = 'rgba(0,0,0,0.05)'; });
            subA.addEventListener('mouseleave', function() { this.style.background = ''; });
            var subBadge = badges[sub.title.trim()];
            if (subBadge) subA.appendChild(makeBadgeSpan(subBadge));
            subLi.appendChild(subA);
            subUl.appendChild(subLi);
          });

          // Show/hide via JS events (works on all themes, not just CSS hover)
          li.addEventListener('mouseenter', function() { subUl.style.display = 'block'; });
          li.addEventListener('mouseleave', function() { subUl.style.display = 'none'; });
          li.appendChild(subUl);
        }

        ul.appendChild(li);
      });

      nav.setAttribute('data-tree-master-original', nav.innerHTML);
      nav.setAttribute('data-tree-master-native', nativeMenuHandle);
      nav.innerHTML = '';
      nav.appendChild(ul);
      console.log("Tree Master: native menu injected (" + items.length + " items).");
      return true;
    }

    function loadNativeBadges() {
      if (!nativeMenuHandle) return;
      var items = getMenuItemsFromDOM();
      fetch('/apps/tree-master/native-badges/' + nativeMenuHandle + '?shop=' + shop)
        .then(function(res) { return res.ok ? res.json() : null; })
        .then(function(data) {
          var badges = (data && data.badges) ? data.badges : {};
          if (items) {
            buildAndInjectNativeMenu(items, badges);
          } else {
            injectBadgesOnly(badges);
          }
        })
        .catch(function() {
          if (items) buildAndInjectNativeMenu(items, {});
        });
    }

    // ---- Custom menu injection ----
    function injectMenu() {
      fetch("/apps/tree-master/menu/" + menuId)
        .then(function(res) {
          if (!res.ok) throw new Error("HTTP " + res.status);
          return res.json();
        })
        .then(function(data) {
          if (!data.html) {
            console.warn("Tree Master: menu has no HTML. Is it published?");
            return;
          }
          var nav = findNav();
          if (!nav) {
            console.warn("Tree Master: nav not found. Try setting a CSS selector in App Embeds settings.");
            return;
          }
          if (data.css) {
            var style = document.createElement("style");
            style.setAttribute("data-tree-master", menuId);
            style.textContent = data.css;
            document.head.appendChild(style);
          }
          nav.setAttribute("data-tree-master-original", nav.innerHTML);
          nav.setAttribute("data-tree-master-id", menuId);
          nav.innerHTML = data.html;
          if (data.js) {
            try { (new Function(data.js))(); }
            catch (e) { console.error("Tree Master JS error:", e); }
          }
          console.log("Tree Master: custom menu injected.");
        })
        .catch(function(err) {
          console.error("Tree Master: failed to load menu.", err);
        });
    }

    function init() {
      if (menuId) injectMenu();
      if (nativeMenuHandle) loadNativeBadges();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
{% endif %}

{% schema %}
{
  "name": "Tree Master Menu",
  "target": "body",
  "settings": [
    {
      "type": "header",
      "content": "Custom Code Menu"
    },
    {
      "type": "text",
      "id": "custom_menu_id",
      "label": "Custom Menu ID",
      "info": "Enter the menu ID from the Tree Master app (Custom Menus section). Leave empty if not using a custom menu."
    },
    {
      "type": "text",
      "id": "nav_selector",
      "label": "Navigation CSS Selector (optional)",
      "placeholder": "header nav",
      "info": "Leave empty to auto-detect. If the menu doesn't appear, open DevTools, find your nav element, and enter its selector here."
    },
    {
      "type": "header",
      "content": "Native Menu Badges"
    },
    {
      "type": "text",
      "id": "native_menu_handle",
      "label": "Menu Handle",
      "info": "Enter your Shopify menu handle (e.g. 'main-menu'). The menu items will be displayed in your header navigation. To show badges, add them to items in Tree Master and Save."
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge Color",
      "default": "#FF4438"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
