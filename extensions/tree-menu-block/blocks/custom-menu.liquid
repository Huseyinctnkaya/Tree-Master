{% comment %}
  Tree Master - App Embed
  • Custom Menu: replaces header nav with a custom-coded menu
  • Native Badges: injects badges into the existing Shopify nav
{% endcomment %}

{% assign menu_id = block.settings.custom_menu_id %}
{% assign nav_selector = block.settings.nav_selector %}
{% assign native_menu_handle = block.settings.native_menu_handle %}
{% assign badge_color = block.settings.badge_color %}
{% assign badge_text_color = block.settings.badge_text_color %}
{% if nav_selector == blank %}{% assign nav_selector = "header nav" %}{% endif %}

{% if menu_id != blank or native_menu_handle != blank %}
<style>
  .tm-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 9px;
    font-weight: 800;
    line-height: 1;
    padding: 3px 7px;
    border-radius: 20px;
    margin-left: 6px;
    vertical-align: middle;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background-color: {{ badge_color | default: '#FF4438' }};
    color: {{ badge_text_color | default: '#ffffff' }};
    white-space: nowrap;
    pointer-events: none;
    position: relative;
    top: -1px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.18);
    animation: tm-badge-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes tm-badge-pop {
    from { transform: scale(0.6); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }
</style>
<script>
  (function() {
    var menuId = {{ menu_id | json }};
    var customSelector = {{ nav_selector | json }};
    var nativeMenuHandle = {{ native_menu_handle | json }};
    var shop = {{ shop.permanent_domain | json }};

    // Fallback selectors — more specific first (Dawn, Refresh, Sense, etc.)
    var fallbackSelectors = [
      customSelector,
      ".header__inline-menu",
      "header .header__navigation",
      ".site-navigation",
      ".site-nav",
      "header nav",
      "header [role='navigation']"
    ];

    function isVisible(el) {
      if (!el) return false;
      var style = window.getComputedStyle(el);
      if (style.display === "none" || style.visibility === "hidden" || style.opacity === "0") return false;
      var rect = el.getBoundingClientRect();
      return rect.width > 0 || rect.height > 0;
    }

    function findNav() {
      for (var i = 0; i < fallbackSelectors.length; i++) {
        var candidates = document.querySelectorAll(fallbackSelectors[i]);
        for (var j = 0; j < candidates.length; j++) {
          if (isVisible(candidates[j])) {
            console.log("Tree Master: nav found with selector \"" + fallbackSelectors[i] + "\"");
            return candidates[j];
          }
        }
      }
      return null;
    }

    // ---- Native menu + badge injection ----
    function escapeHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function makeBadgeSpan(text) {
      var span = document.createElement('span');
      span.className = 'tm-badge';
      span.textContent = text;
      return span;
    }

    function getLinkText(link) {
      var clone = link.cloneNode(true);
      clone.querySelectorAll('.tm-badge').forEach(function(b) { b.remove(); });
      return clone.textContent.trim();
    }

    // Inject badges onto already-rendered nav links (fallback when no items returned)
    function injectBadgesOnly(badges) {
      if (!badges || Object.keys(badges).length === 0) return;
      var links = document.querySelectorAll('header a, nav a, [role="navigation"] a');
      links.forEach(function(link) {
        var text = getLinkText(link);
        if (text && badges[text] && !link.querySelector('.tm-badge')) {
          link.appendChild(makeBadgeSpan(badges[text]));
        }
      });
    }

    // Replace nav with Shopify menu items and inject badges
    function buildAndInjectNativeMenu(items, badges) {
      if (!items || items.length === 0) return false;

      var nav = findNav();
      if (!nav) {
        console.warn("Tree Master: could not find header navigation. Try setting a custom CSS selector in App Embeds settings.");
        return false;
      }

      // Detect nav structure to preserve theme styling
      var existingLink = nav.querySelector('a');
      var linkClass = existingLink ? existingLink.className : '';
      var existingUl = nav.querySelector('ul');
      var listClass = existingUl ? existingUl.className : '';
      var existingLi = nav.querySelector('li');
      var liClass = existingLi ? existingLi.className : '';
      var useList = !!existingLi;

      var html = useList ? ('<ul' + (listClass ? ' class="' + escapeHtml(listClass) + '"' : '') + '>') : '';

      items.forEach(function(item) {
        var badge = badges[item.title ? item.title.trim() : ''];
        var badgeHtml = badge ? '<span class="tm-badge">' + escapeHtml(badge) + '</span>' : '';
        var linkHtml = '<a href="' + escapeHtml(item.url) + '"'
          + (linkClass ? ' class="' + escapeHtml(linkClass) + '"' : '') + '>'
          + escapeHtml(item.title) + badgeHtml + '</a>';

        // Sub-items
        if (item.items && item.items.length > 0 && useList) {
          var subHtml = '<ul>';
          item.items.forEach(function(sub) {
            var subBadge = badges[sub.title ? sub.title.trim() : ''];
            var subBadgeHtml = subBadge ? '<span class="tm-badge">' + escapeHtml(subBadge) + '</span>' : '';
            subHtml += '<li><a href="' + escapeHtml(sub.url) + '"'
              + (linkClass ? ' class="' + escapeHtml(linkClass) + '"' : '') + '>'
              + escapeHtml(sub.title) + subBadgeHtml + '</a></li>';
          });
          subHtml += '</ul>';
          html += useList
            ? ('<li' + (liClass ? ' class="' + escapeHtml(liClass) + '"' : '') + '>' + linkHtml + subHtml + '</li>')
            : linkHtml;
        } else {
          html += useList
            ? ('<li' + (liClass ? ' class="' + escapeHtml(liClass) + '"' : '') + '>' + linkHtml + '</li>')
            : linkHtml;
        }
      });

      if (useList) html += '</ul>';

      nav.setAttribute("data-tree-master-original", nav.innerHTML);
      nav.setAttribute("data-tree-master-native", nativeMenuHandle);
      nav.innerHTML = html;
      console.log("Tree Master: native menu injected with " + items.length + " items.");
      return true;
    }

    function loadNativeBadges() {
      if (!nativeMenuHandle) return;
      fetch('/apps/tree-master/native-badges/' + nativeMenuHandle + '?shop=' + shop)
        .then(function(res) { return res.ok ? res.json() : null; })
        .then(function(data) {
          if (!data) return;
          // If API returned menu items, replace nav + inject badges
          if (data.items && data.items.length > 0) {
            buildAndInjectNativeMenu(data.items, data.badges || {});
          } else if (data.badges && Object.keys(data.badges).length > 0) {
            // Fallback: only inject badges onto existing nav links
            injectBadgesOnly(data.badges);
          }
        })
        .catch(function() {});
    }

    // ---- Custom menu injection ----
    function injectMenu() {
      fetch("/apps/tree-master/menu/" + menuId)
        .then(function(res) {
          if (!res.ok) throw new Error("HTTP " + res.status);
          return res.json();
        })
        .then(function(data) {
          if (!data.html) {
            console.warn("Tree Master: menu has no HTML. Is it published?");
            return;
          }

          var nav = findNav();
          if (!nav) {
            console.warn("Tree Master: could not find header navigation. Try setting a custom CSS selector in App Embeds settings.");
            return;
          }

          // Inject CSS
          if (data.css) {
            var style = document.createElement("style");
            style.setAttribute("data-tree-master", menuId);
            style.textContent = data.css;
            document.head.appendChild(style);
          }

          // Replace nav's inner content with custom menu
          nav.setAttribute("data-tree-master-original", nav.innerHTML);
          nav.setAttribute("data-tree-master-id", menuId);
          nav.innerHTML = data.html;

          // Execute custom JS
          if (data.js) {
            try {
              var fn = new Function(data.js);
              fn();
            } catch (e) {
              console.error("Tree Master: JS error:", e);
            }
          }

          console.log("Tree Master: menu injected successfully.");
        })
        .catch(function(err) {
          console.error("Tree Master: Failed to load menu.", err);
        });
    }

    function init() {
      if (menuId) injectMenu();
      if (nativeMenuHandle) loadNativeBadges();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
{% endif %}

{% schema %}
{
  "name": "Tree Master Menu",
  "settings": [
    {
      "type": "header",
      "content": "Custom Code Menu"
    },
    {
      "type": "text",
      "id": "custom_menu_id",
      "label": "Custom Menu ID",
      "info": "Enter the menu ID from the Tree Master app (Custom Menus section). Leave empty if not using a custom menu."
    },
    {
      "type": "text",
      "id": "nav_selector",
      "label": "Navigation CSS Selector (optional)",
      "placeholder": "header nav",
      "info": "Leave empty to auto-detect. If the menu doesn't appear, open DevTools, find your nav element, and enter its selector here."
    },
    {
      "type": "header",
      "content": "Native Menu Badges"
    },
    {
      "type": "text",
      "id": "native_menu_handle",
      "label": "Menu Handle",
      "info": "Enter your Shopify menu handle (e.g. 'main-menu'). The menu items will be displayed in your header navigation. To show badges, add them to items in Tree Master and Deploy."
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge Color",
      "default": "#FF4438"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
