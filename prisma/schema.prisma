// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Stores snapshots of Shopify menus (drafts + version history)
model MenuSnapshot {
  id         String   @id @default(cuid())
  shop       String
  menuGid    String   // Shopify menu GID e.g. gid://shopify/Menu/123
  menuHandle String
  menuTitle  String
  data       String   // JSON string of the full menu tree
  note       String?  // Optional user note for this snapshot
  createdAt  DateTime @default(now())

  @@index([shop, menuGid])
}

// Extra metadata for menu items (handle, SEO, meta description)
model MenuMeta {
  id        String   @id @default(cuid())
  shop      String
  menuGid   String
  data      String   // JSON: { [itemId]: { handle, seoKeywords, metaDescription } }
  updatedAt DateTime @updatedAt

  @@unique([shop, menuGid])
  @@index([shop, menuGid])
}

// Custom code menus (HTML/CSS created in app)
model CustomMenu {
  id        String   @id @default(cuid())
  shop      String
  name      String
  html      String   @default("")
  css       String   @default("")
  status    String   @default("draft") // draft | published
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([shop, status])
}

// Webhook endpoints called on menu deploy
model WebhookConfig {
  id        String   @id @default(cuid())
  shop      String
  url       String
  label     String   @default("")
  createdAt DateTime @default(now())

  @@index([shop])
}

// Scheduled menu deployments
model ScheduledDeploy {
  id         String   @id @default(cuid())
  shop       String
  menuGid    String
  menuHandle String
  menuTitle  String
  data       String   // JSON string of the menu items to deploy
  scheduledAt DateTime // When to deploy
  status     String   @default("pending") // pending | deployed | cancelled
  createdAt  DateTime @default(now())

  @@index([shop, status])
  @@index([scheduledAt, status])
}
